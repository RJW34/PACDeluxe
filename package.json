{
  "name": "pac-deluxe",
  "version": "2.0.7",
  "description": "Native performance client for Pokemon Auto Chess",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.js",
    "sync-upstream": "node scripts/sync-upstream.js",
    "build:frontend": "node scripts/build-frontend.js",
    "build:frontend:dev": "node scripts/build-frontend.js --dev",
    "dev:server": "node scripts/dev-server.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:no-bundle": "tauri build --no-bundle",
    "dev": "npm run tauri:dev",
    "dev:static": "npm run build:frontend:dev && npm run tauri:dev -- --no-dev-server",
    "build": "npm run build:frontend && npm run tauri:build",
    "release:sign": "node scripts/sign-release-artifacts.js",
    "release:manifest": "node scripts/write-updater-manifest.js",
    "verify:release": "node scripts/verify-release-artifacts.js --require-signatures",
    "verify:updater": "node scripts/verify-updater-endpoint.js",
    "validate": "node scripts/validate-determinism.js",
    "verify:manifest": "node scripts/verify-build-manifest.js",
    "verify": "npm test && npm run validate && npm run verify:manifest && cargo check --manifest-path src-tauri/Cargo.toml --message-format short",
    "test": "node --test tests/ethical-safeguards.test.js",
    "lint": "biome lint scripts tests"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/cli": "^2.9.5",
    "esbuild": "^0.24.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
