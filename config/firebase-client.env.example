# Copy this file to config/firebase-client.env or export the same variables
# in your shell before running `npm run build:frontend`.
#
# These values are public client-side Firebase configuration values used by
# the upstream web client. They must be supplied explicitly; PACDeluxe no
# longer scrapes them from the live production site at build time.

FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""

